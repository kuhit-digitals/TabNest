{
  "manifest_version": 3,
  "name": "TabNest",
  "version": "1.0.0",
  "description": "Save and restore browser workspaces using natural language.",

  "action": {
    "default_popup": "popup.html"
  },

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ]
}